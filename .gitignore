# ── Secrets — NEVER commit ────────────────────────────────────────────────
.env
*.env
!*.env.example

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ── OS / editor / tooling ─────────────────────────────────────────────────
.DS_Store
*.bak
.claude/

